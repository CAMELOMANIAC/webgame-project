// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl      = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nickname  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stash      StashItem[]
  snapshots  GhostSnapshot[]
  character  Character?
}

model Character {
  id        String   @id @default(uuid())
  userId    String   @unique
  hp        Int      @default(100)
  maxHp     Int      @default(100)
  stamina   Int      @default(100)
  maxStamina Int     @default(100)
  staminaRegen Int   @default(10)
  weight    Int      @default(0)
  maxWeight Int      @default(50)
  day       Int      @default(0)
  isRaiding Boolean  @default(false)
  
  user      User     @relation(fields: [userId], references: [id])
  weapons   CharacterWeapon[]
  inventory RaidInventoryItem[]
}

model CharacterWeapon {
  id             String       @id @default(uuid())
  characterId    String
  weaponMasterId String
  slotIndex      Int          // 0~5
  
  character      Character    @relation(fields: [characterId], references: [id])
  weaponMaster   WeaponMaster @relation(fields: [weaponMasterId], references: [id])

  @@unique([characterId, slotIndex])
}

model RaidInventoryItem {
  id             String       @id @default(uuid())
  characterId    String
  weaponMasterId String
  quantity       Int          @default(1)
  
  character      Character    @relation(fields: [characterId], references: [id])
  weaponMaster   WeaponMaster @relation(fields: [weaponMasterId], references: [id])
}

model WeaponMaster {
  id            String   @id @default(uuid())
  name          String
  damage        Int
  staminaCost   Int
  cooldownTicks Int
  castTicks     Int
  weight        Int
  value         Int
  description   String?

  stashItems    StashItem[]
  ghostWeapons  GhostWeapon[]
  charWeapons   CharacterWeapon[]
  raidInventory RaidInventoryItem[]
}

model StashItem {
  id             String       @id @default(uuid())
  userId         String
  weaponMasterId String
  quantity       Int          @default(1)
  
  user           User         @relation(fields: [userId], references: [id])
  weaponMaster   WeaponMaster @relation(fields: [weaponMasterId], references: [id])
}

model GhostSnapshot {
  id          String   @id @default(uuid())
  userId      String
  nodeId      String   // 필드 노드 ID
  day         Int      // 진행 날짜
  hp          Int
  maxHp       Int
  stamina     Int
  maxStamina  Int
  staminaRegen Int
  weight      Int
  maxWeight   Int
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  weapons     GhostWeapon[]
}

model GhostWeapon {
  id              String        @id @default(uuid())
  snapshotId      String
  weaponMasterId  String
  slotIndex       Int           // 0~5 슬롯 인덱스

  snapshot        GhostSnapshot @relation(fields: [snapshotId], references: [id])
  weaponMaster    WeaponMaster  @relation(fields: [weaponMasterId], references: [id])
}
